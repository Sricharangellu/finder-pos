{
  "name": "ascend-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "test:components": "vitest run tests/Button.test.tsx tests/Input.test.tsx tests/catalogCart.test.tsx",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "generate:client": "openapi-typescript ../contracts/openapi.yaml -o api-client/types.ts",
    "postinstall": "msw init public/ --save 2>/dev/null || true",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "14.2.29",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@emnapi/wasi-threads": "1.2.2",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.29",
    "jsdom": "^25.0.1",
    "msw": "^2.6.4",
    "openapi-typescript": "^7.4.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.7.3",
    "vitest": "^2.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "overrides": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@emnapi/wasi-threads": "1.2.2"
  }
}
