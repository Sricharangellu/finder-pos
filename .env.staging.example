# Ascend — TESTING tier (Supabase B) local env template.
# Copy to `.env` in a clone you use for staging/testing work. NEVER put the
# production (Supabase A) connection string here. See docs/architecture/PIPELINE.md.

# ── Supabase Postgres — TESTING project (B) ──────────────────────────────────
# Session pooler URI of the `ascend-testing` Supabase project:
#   postgresql://postgres.<ref>:<PW>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase requires TLS. Prefer verified TLS with the Supabase CA in real infra:
#   PG_CA_CERT=... (dashboard → Settings → Database → SSL)
# For a quick local dev connection through the pooler you may instead skip
# verification (traffic still encrypted). Do NOT use PG_SSL_NO_VERIFY in prod.
PG_SSL=require
PG_SSL_NO_VERIFY=1
PG_POOL_MAX=5

# ── Auth (staging — DO NOT reuse the prod JWT secret) ────────────────────────
JWT_SECRET=

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
