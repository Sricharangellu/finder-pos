# ── Database ──────────────────────────────────────────────────────────────────
# Direct Postgres connection string. For managed services that use connection
# pooling (Neon, Railway, Supabase), use the POOLED / proxy connection string
# here, not the direct connection — direct connections bypass the pooler and
# exhaust Postgres' max_connections limit on serverless deployments.
#   Neon:    use the "Pooled connection" string (ends in ?pgbouncer=true)
#   Railway: use the proxy URL from the Variables tab, not the private URL
DATABASE_URL=postgresql://finder:finder@localhost:5432/finder_dev

# Maximum Postgres connections per process instance. Tune based on your plan:
#   Local dev:           10  (default)
#   Neon / Railway free: 5   (25-connection limit ÷ up to 5 serverless instances)
#   Neon / Railway pro:  20  (scale with your plan's connection limit)
# Formula: PG_POOL_MAX = floor(plan_max_connections / max_instances) - 2
PG_POOL_MAX=10
# Max milliseconds a single database transaction may run before Postgres kills it.
# Prevents runaway transactions from holding row locks and exhausting the pool.
PG_TX_TIMEOUT_MS=30000

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production. Must be ≥ 32 random characters.
JWT_SECRET=change-me-min-32-chars-random-string

# ── App URLs (REQUIRED in production) ─────────────────────────────────────────
# Public URL of this backend service (used in CORS, email links, OAuth redirects).
APP_URL=http://localhost:3001
# URL the Next.js frontend uses to reach this backend (for server-side fetches).
BACKEND_URL=http://localhost:3001

# ── Security ──────────────────────────────────────────────────────────────────
# Number of trusted proxy hops between the internet and this server.
# Set to 1 for Vercel (1 proxy layer). Set to 2 for Cloudflare + Vercel.
# Controls X-Forwarded-For depth used by the rate limiter to extract real client IP.
TRUST_PROXY_DEPTH=1

# ── Redis (optional — enables distributed rate limiting and durable EventBus) ──
# Without Redis, rate limiting is per-instance (in-memory) and EventBus events
# do not propagate across instances. Set this in production multi-instance deploys.
# Supported: redis://host:6379 or rediss://host:6380 (TLS).
REDIS_URL=

# ── Stripe (optional — required to accept card payments) ──────────────────────
# Obtain from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Register a Stripe Terminal reader in the Dashboard and put its ID here.
STRIPE_TERMINAL_READER_ID=
# Stripe webhook endpoint secret for signature verification (from webhook dashboard).
STRIPE_WEBHOOK_SECRET=

# ── Email (optional — dev mode logs to console if unset) ─────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=receipts@yourstore.com
EMAIL_WEBHOOK_URL=

# ── Observability ─────────────────────────────────────────────────────────────
# Bearer token required to scrape the /metrics endpoint (Prometheus).
# Leave empty to allow unauthenticated access (not recommended in production).
METRICS_TOKEN=

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Store ─────────────────────────────────────────────────────────────────────
STORE_NAME=FinderPOS Demo

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (production) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Defaults to the Vercel
# deployment URLs if unset. In dev, all origins are permitted.
ALLOWED_ORIGINS=https://finder-pos-frontend.vercel.app
