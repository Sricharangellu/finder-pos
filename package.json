{
  "name": "ascend",
  "version": "2.0.0",
  "description": "Ascend - Year 1 Foundation (modular monolith). Offline-first POS backend on Postgres.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "start": "tsx --env-file-if-exists=.env src/server.ts",
    "db:setup": "bash scripts/db-setup.sh",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx scripts/test.ts",
    "smoke": "tsx scripts/smoke.ts",
    "hygiene": "node tools/hygiene-check.mjs",
    "ops:check": "tsx scripts/ops-check.ts",
    "prevent:drift": "node tools/prevention-agent.mjs",
    "seed:e2e": "tsx scripts/seed-e2e.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "verify": "npm run hygiene && npm run typecheck && npm test && npm run smoke && npm --prefix web run typecheck && npm --prefix web run lint && npm --prefix web run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.21.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "otpauth": "^9.5.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "stripe": "22.2.2",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "embedded-postgres": "18.4.0-beta.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
