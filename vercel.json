{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "redirects": [
    { "source": "/", "destination": "/health", "permanent": false }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/jobs/tick", "schedule": "0 6 * * *" }
  ]
}
